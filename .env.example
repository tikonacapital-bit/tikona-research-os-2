# Supabase — Settings → API in your Supabase project
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Anthropic — used directly from the browser by the /admin/pipeline flow
VITE_ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# n8n — required by the /admin/system-health dashboard
VITE_N8N_API_KEY=your-n8n-api-key-here
