      "parameters": {
        "jsCode": "const allFiles = $input.all();\nconst folderInfo = $('Final Folder ID1').first().json;\nconst nseSymbol = $('Webhook3').first().json.body.nse_symbol;\n\n// Sort files by createdTime descending (newest first)\nconst sortedFiles = allFiles.map(item => item.json).sort((a, b) => {\n    return new Date(b.createdTime || 0) - new Date(a.createdTime || 0);\n});\n\nconst cleanFiles = [];\nconst seenNames = new Set();\n\nfor (const f of sortedFiles) {\n    if (!f.name) continue;\n    \n    // Clean name and check for duplicates\n    const cleanName = f.name.trim();\n    if (seenNames.has(cleanName)) continue;\n    seenNames.add(cleanName);\n    \n    // Explicitly check the file name to assign the perfect category\n    let docType = \"Document\";\n    if (cleanName.includes(\"Concall Transcript\")) {\n        docType = \"Concall Transcript\";\n    } else if (cleanName.includes(\"Annual Report\")) {\n        docType = \"Annual Report\";\n    } else if (cleanName.includes(\"Investor PPT\")) {\n        docType = \"Investor PPT\";\n    } else if (cleanName.includes(\"Financial Model\") || cleanName.includes(\"Excel\")) {\n        docType = \"Financial Model\";\n    } else if (cleanName.includes(\"Podcast\") || cleanName.includes(\"Audio\")) {\n        docType = \"Podcast\";\n    } else if (cleanName.includes(\"Video\")) {\n        docType = \"Video\";\n    }\n\n    cleanFiles.push({\n        id: f.id,\n        name: cleanName,\n        type: docType, \n        webViewLink: f.webViewLink || \"Link not fetched\",\n        webContentLink: f.webContentLink || \"Download not fetched\",\n        createdTime: f.createdTime\n    });\n}\n\n// Optional: Sort cleanFiles alphabetically by name for a cleaner UI list\ncleanFiles.sort((a, b) => a.name.localeCompare(b.name));\n\nreturn [{\n    json: {\n        status: \"success\",\n        company: nseSymbol,\n        main_folder_id: folderInfo.id,\n        total_files: cleanFiles.length,\n        files: cleanFiles\n    }\n}];"
      },
