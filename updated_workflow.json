    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst successful = [];\n\nfor (let i = 0; i < items.length; i++) {\n    const item = items[i];\n    if (item.error) continue;\n    if (!item.binary || !item.binary.data) continue;\n    successful.push(item);\n}\n\nreturn successful;"
