    {
      "parameters": {
        "jsCode": "const root = \"https://www.screener.in\";\nconst results = [];\nconst debugLog = [];\n\nconst item = $input.first().json;\n\n// Get NSE Symbol\nlet nseSymbol = \"UNKNOWN\";\ntry {\n    nseSymbol = $('Webhook3').first().json.body.nse_symbol;\n} catch (e) {\n    if (item.body && item.body.nse_symbol) nseSymbol = item.body.nse_symbol;\n}\n\n// --- Helper: Extract Quarter from text ---\nfunction extractQuarter(text) {\n    const cleanText = text.replace(/<[^>]+>/g, ' ');\n    \n    // Pattern 1: Explicit \"Q3 FY25\" format\n    let qMatch = cleanText.match(/Q([1-4])\\s*FY\\s*(\\d{2,4})/i);\n    if (qMatch) {\n        let fy = qMatch[2];\n        if (fy.length === 4) fy = fy.slice(2);\n        return `Q${qMatch[1]} FY${fy}`;\n    }\n    \n    // Pattern 2: \"Mon YYYY\" format (e.g., \"Jan 2026\") → derive quarter from month\n    const months = { jan:0, feb:1, mar:2, apr:3, may:4, jun:5, jul:6, aug:7, sep:8, oct:9, nov:10, dec:11 };\n    const monMatch = cleanText.match(/(Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec)[a-z]*\\s+(\\d{4})/i);\n    if (monMatch) {\n        const monthIdx = months[monMatch[1].substring(0, 3).toLowerCase()];\n        const calYear = parseInt(monMatch[2]);\n        \n        const quarterMap = {\n            0:  { q: 3, fyOffset: 0 },   // Jan\n            1:  { q: 3, fyOffset: 0 },   // Feb\n            2:  { q: 4, fyOffset: 0 },   // Mar\n            3:  { q: 4, fyOffset: 0 },   // Apr\n            4:  { q: 4, fyOffset: 0 },   // May\n            5:  { q: 4, fyOffset: 0 },   // Jun\n            6:  { q: 1, fyOffset: 1 },   // Jul\n            7:  { q: 1, fyOffset: 1 },   // Aug\n            8:  { q: 1, fyOffset: 1 },   // Sep\n            9:  { q: 2, fyOffset: 1 },   // Oct\n            10: { q: 2, fyOffset: 1 },   // Nov\n            11: { q: 2, fyOffset: 1 },   // Dec\n        };\n        \n        const mapping = quarterMap[monthIdx];\n        const fy = (calYear + mapping.fyOffset) % 100;\n        return `Q${mapping.q} FY${fy}`;\n    }\n    \n    return \"\";\n}\n\n// --- Filename: \"SYMBOL - Quarter - Type.pdf\" ---\nfunction getFileName(type, extension, quarterOrFy = \"\") {\n    const timeSuffix = quarterOrFy ? ` - ${quarterOrFy}` : \"\";\n    return `${nseSymbol}${timeSuffix} - ${type}.${extension}`;\n}\n\nfunction extractLinkInfo(htmlString) {\n    // Corrected to reliably find href regardless of nested tags\n    const hrefMatch = htmlString.match(/href=[\"']([^\"']+)[\"']/i);\n    // Corrected: Safely strip all HTML tags (like <i> or <span>) to get clear readable text\n    const text = htmlString.replace(/<[^>]+>/g, ' ').trim();\n    return {\n        url: hrefMatch ? hrefMatch[1] : null,\n        text: text\n    };\n}\n\nfunction detectDocumentType(url, text) {\n    const lowerUrl = url ? url.toLowerCase() : \"\";\n    const lowerText = text ? text.toLowerCase() : \"\";\n    \n    if (lowerText.includes('transcript') || lowerText === 'transcript') {\n        if (!lowerUrl.includes('youtube') && !lowerUrl.includes('youtu.be')) return 'Concall Transcript';\n    }\n    if (lowerText.includes('ppt') || lowerText === 'ppt' || lowerText.includes('presentation')) return 'Investor PPT';\n    \n    if (lowerUrl.includes('transcript') && !lowerUrl.includes('youtube')) return 'Concall Transcript';\n    if (lowerUrl.includes('shareholder') || lowerUrl.includes('presentation')) return 'Investor PPT';\n    \n    return null;\n}\n\n// --- 1. ANNUAL REPORT ---\nif (item.annual_report) {\n    let url = item.annual_report;\n    if (url.startsWith('/')) url = root + url;\n    \n    let today = new Date();\n    let calYear = today.getFullYear();\n    let calMonth = today.getMonth();\n    let arFYNum = calMonth >= 6 ? (calYear % 100) : ((calYear - 1) % 100);\n    let arFYString = `FY${arFYNum}`;\n\n    results.push({\n        url: url,\n        filename: getFileName(\"Annual Report\", \"pdf\", arFYString),\n        type: \"Annual Report\",\n        quarter: arFYString\n    });\n}\n\n// --- 2. CONCALL LINKS (4 Transcripts + 1 PPT) ---\nif (item.concall_links && Array.isArray(item.concall_links)) {\n    // Corrected: Use a Set to track distinct quarters rather than arbitrary matches\n    let transcriptQuarters = new Set();\n    let pptFound = false;\n    \n    for (let i = 0; i < item.concall_links.length; i++) {\n        const htmlChunk = item.concall_links[i];\n        \n        const detectedQuarter = extractQuarter(htmlChunk);\n        \n        if (!detectedQuarter) {\n            debugLog.push(`Chunk ${i}: Skipped - no quarter found`);\n            continue;\n        }\n        \n        debugLog.push(`Chunk ${i}: Quarter=${detectedQuarter}`);\n        \n        // Corrected Regex: Catches the entire <a> tag, even if it contains inner icons/elements.\n        const linkMatches = htmlChunk.match(/<a\\b[^>]*>[\\s\\S]*?<\\/a>/gi) || [];\n        \n        for (const linkHtml of linkMatches) {\n            const linkInfo = extractLinkInfo(linkHtml);\n            if (!linkInfo.url) continue;\n            \n            const docType = detectDocumentType(linkInfo.url, linkInfo.text);\n            let finalUrl = linkInfo.url.startsWith('/') ? root + linkInfo.url : linkInfo.url;\n            \n            if (docType === 'Concall Transcript' && transcriptQuarters.size < 4) {\n                // Corrected: Deduplicate within the same quarter to prevent loop terminating early\n                if (!transcriptQuarters.has(detectedQuarter)) {\n                    transcriptQuarters.add(detectedQuarter);\n                    results.push({\n                        url: finalUrl,\n                        filename: getFileName(\"Concall Transcript\", \"pdf\", detectedQuarter),\n                        type: \"Concall Transcript\",\n                        quarter: detectedQuarter\n                    });\n                }\n            }\n            \n            if (docType === 'Investor PPT' && !pptFound) {\n                pptFound = true;\n                results.push({\n                    url: finalUrl,\n                    filename: getFileName(\"Investor PPT\", \"pdf\", detectedQuarter),\n                    type: \"Investor PPT\",\n                    quarter: detectedQuarter\n                });\n            }\n        }\n        \n        if (transcriptQuarters.size >= 4 && pptFound) break;\n    }\n}\n\nif (results.length > 0 && debugLog.length > 0) {\n    results[0].debug_log = debugLog.join('\\n');\n}\n\nreturn results.map(item => ({ json: item }));\n"
      },
