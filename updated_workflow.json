    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst cleanItems = [];\n\nfor (const item of items) {\n    const data = item.json;\n    if (!data.url) continue;\n    \n    // Clean URL\n    const cleanUrl = data.url.trim();\n    const url = cleanUrl.toLowerCase();\n    \n    const isSwiggy = url.includes('swiggy.com');\n    const isBSE = url.includes('bseindia.com');\n    \n    cleanItems.push({\n        json: {\n            ...data,\n            url: cleanUrl,\n            source: isSwiggy ? 'swiggy' : (isBSE ? 'bse' : 'other')\n        }\n    });\n}\n\nreturn cleanItems;"
      },
